# ============ 动环监控预警平台 环境变量示例 ============
# 复制为 .env 后按需修改；docker-compose 会读取本文件做变量替换。

# ---- 应用 ----
ENVIRONMENT=development
TZ=Asia/Shanghai
LOG_LEVEL=INFO

# ---- PostgreSQL / TimescaleDB ----
POSTGRES_USER=dcim
POSTGRES_PASSWORD=dcim_pass
POSTGRES_DB=dcim
# 容器内固定为服务名 db；本机直连时改为 localhost
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- JWT 登录态 ----
JWT_SECRET=please-change-this-secret
JWT_EXPIRE_MINUTES=720

# ---- 对称加密密钥（EMS 凭据加密）----
# 生产请用 python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())" 生成
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# ---- 默认管理员（首次启动创建）----
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ---- EMS 连接默认值（首次启动 seed 到 ems_config；密码加密入库）----
# 容器内联调指向 ems_mock 服务；recv_ip/port 为 backend 对 EMS 可达的接收地址
EMS_BASE_URL=http://ems_mock:9000
EMS_USERNAME=admin
EMS_PASSWORD=123456
EMS_RECV_IP=backend
EMS_RECV_PORT=8000
EMS_VERSION=20170714124155
EMS_AUTO_CONNECT=true

# ---- 对外端口映射 ----
BACKEND_PORT=8000
FRONTEND_PORT=8080
EMS_MOCK_PORT=9000
